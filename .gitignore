# =============================================================
# OpenClaw Research — .gitignore
# =============================================================

# ──────────────────────────────────────────
# 环境变量 & 密钥（绝不提交）
# ──────────────────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────────────────────
# Python 编译缓存
# ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
wheels/
.eggs/
pip-wheel-metadata/

# ──────────────────────────────────────────
# 虚拟环境
# ──────────────────────────────────────────
.venv/
venv/
env/
ENV/
.python-version

# ──────────────────────────────────────────
# data/ 运行时动态内容（各子目录内置 .gitignore 管理）
# ──────────────────────────────────────────

# SQLite 数据库
data/*.db
data/*.sqlite
data/*.sqlite3

# ChromaDB 向量持久化（整目录，运行时自动生成）
data/chroma/

# claw 日志目录
claw/config/logs/

# ──────────────────────────────────────────
# Claw 运行时配置（含凭据，禁止提交）
# ──────────────────────────────────────────
claw/config/credentials/
claw/config/feishu/          # 含去重记录 dedup/main.json、飞书凭据等运行时数据
claw/config/devices/
claw/config/identity/
claw/config/agents/main/sessions/
claw/config/openclaw.json
claw/config/openclaw.json.bak*
claw/config/exec-approvals.json
claw/config/update-check.json
claw/config/node.json
claw/workspace/

# ──────────────────────────────────────────
# 备份文件
# ──────────────────────────────────────────
*.bak
*.bak.*

# ──────────────────────────────────────────
# IDE & 编辑器
# ──────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ──────────────────────────────────────────
# 测试 & 覆盖率
# ──────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ──────────────────────────────────────────
# 前端构建产物（web/static 由构建流程生成）
# ──────────────────────────────────────────
web/static/dist/
node_modules/

# ──────────────────────────────────────────
# Docker 本地覆盖
# ──────────────────────────────────────────
docker-compose.override.yml

# ──────────────────────────────────────────
# 临时文件
# ──────────────────────────────────────────
*.log
*.log.*
*.tmp
*.temp
