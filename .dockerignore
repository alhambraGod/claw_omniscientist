# =============================================================================
# .dockerignore — omni-research Docker 构建排除规则
#
# 构建上下文 = 项目根目录（context: ..），只需 Python 源码 + requirements.txt
# 排除所有不必要文件，加速构建、减小镜像层
# =============================================================================

# ── Git / IDE ─────────────────────────────────────────────────────────────────
.git/
.gitignore
.cursor/
.vscode/
*.swp
*.swo

# ── 运行时数据（容器内通过卷挂载注入）────────────────────────────────────────
data/

# ── Docker 部署配置（不需要进镜像）───────────────────────────────────────────
claw/
Dockerfile*
docker-compose*.yml
*.sh

# ── Python 缓存 / 编译文件 ───────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/
*.egg

# ── 虚拟环境 ─────────────────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
.conda/

# ── 文档 ─────────────────────────────────────────────────────────────────────
docs/
*.md
LICENSE

# ── 测试 ─────────────────────────────────────────────────────────────────────
tests/
test_*.py
*_test.py

# ── 临时 / 日志 ───────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
.DS_Store
