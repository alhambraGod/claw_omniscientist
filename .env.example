# =============================================
# OpenClaw 环境配置示例
# 复制为 .env 并填写真实值
# =============================================

# OpenRouter / 自定义推理端点
OPENROUTER_BASE_URL=http://your-openrouter-host:port
OPENAI_API_KEY=sk-your-key-here

# 默认模型
DEFAULT_MODEL=gemini-3.1-pro-preview-thinking
FAST_MODEL=gemini-3.1-pro-preview-thinking

# 服务配置
HOST=0.0.0.0
PORT=10101
DEBUG=false

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/openclaw.db

# 向量数据库 (ChromaDB 本地路径)
CHROMA_DB_PATH=./data/chroma

# 日志级别
LOG_LEVEL=INFO

# 短信配置 (阿里云短信, 可选)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=OpenClaw
ALIYUN_SMS_TEMPLATE_CODE=

# 钉钉集成 (可选)
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_WEBHOOK=

# Tavily 搜索 API (可选, 用于网络搜索)
TAVILY_API_KEY=

# 社区配置
MAX_CLAWER_INSTANCES=10
MAX_CONCURRENT_TASKS=20
TASK_TIMEOUT=300
